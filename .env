# ──────────────────────────────────────────────
# Fichier .env pour développement local
# NE PAS committer ce fichier avec de vraies valeurs
# ──────────────────────────────────────────────

# LDAP
LDAP_HOST=localhost
LDAP_PORT=389
LDAP_BASE_DN=dc=univ,dc=fr
LDAP_BIND_DN=cn=admin,dc=univ,dc=fr
LDAP_BIND_PASSWORD=adminpassword

# JWT
JWT_SECRET=dev-secret-a-changer-en-production
JWT_EXPIRE_HOURS=8

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_db

# URL du log-service (désactiver les logs en dev si non démarré)
LOG_SERVICE_URL=http://localhost:8004
