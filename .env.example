# Exemple de fichier .env pour développement local
# Copier ce fichier en .env et remplir les valeurs
# NE PAS committer le fichier .env avec de vraies valeurs
# ──────────────────────────────────────────────

# LDAP
LDAP_HOST=localhost
LDAP_PORT=389
LDAP_BASE_DN=dc=univ,dc=fr
LDAP_BIND_DN=cn=admin,dc=univ,dc=fr
LDAP_BIND_PASSWORD=your_ldap_admin_password

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE_HOURS=8

# PostgreSQL
DATABASE_URL=postgresql://username:password@host:port/database

# URL du log-service (optionnel)
LOG_SERVICE_URL=http://localhost:8004

